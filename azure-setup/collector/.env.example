# Treat this as a secret. Do not commit populated values.
# Mode selector:
# - otel-collector-config.yaml: Azure Monitor exporter with App Insights connection string (non-preview path)
# - otel-collector-config-otlp-preview.yaml: Native OTLP ingestion endpoints + Entra auth (preview path)
# Required in: both modes
OTEL_CONFIG_FILE=otel-collector-config.yaml

# Optional in: both modes
# Added to exported telemetry as resource attributes `enduser.id`
# and `github.copilot.user.email`.
COPILOT_USER_EMAIL=

# Non-preview exporter path:
# Required in: non-preview mode
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=<your-key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/;LiveEndpoint=https://<region>.livediagnostics.monitor.azure.com/

# Preview native OTLP ingestion path:
# These endpoint URLs come from Application Insights Overview -> OTLP Connection Info,
# or are manually constructed from DCR/DCE details.
# Required in: preview mode
AZURE_MONITOR_TRACES_ENDPOINT=https://<logs-dce-domain>/datacollectionRules/<dcr-immutable-id>/streams/Microsoft-OTLP-Traces/otlp/v1/traces
# Required in: preview mode
AZURE_MONITOR_LOGS_ENDPOINT=https://<logs-dce-domain>/datacollectionRules/<dcr-immutable-id>/streams/Microsoft-OTLP-Logs/otlp/v1/logs
# Required in: preview mode
AZURE_MONITOR_METRICS_ENDPOINT=https://<metrics-dce-domain>/datacollectionRules/<dcr-immutable-id>/streams/Custom-Metrics-Otel/otlp/v1/metrics

# Local Docker auth for preview mode:
# The collector container does not automatically reuse host az login.
# Use a service principal for laptop-based Docker runs.
# Required in: preview mode on local Docker
AZURE_TENANT_ID=
# Required in: preview mode on local Docker
AZURE_CLIENT_ID=
# Required in: preview mode on local Docker
AZURE_CLIENT_SECRET=
