      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "sku": {
        "name": "Standard"
      },
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "publicNetworkAccess": "Enabled",
        "zoneRedundancy": "Disabled",
        "apiKey": "Disabled",
        "deterministicOutboundIP": "Disabled"
      }
    },
    {
      "condition": "[parameters('assignGrafanaMonitoringReader')]",
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceGroup().id, resourceId('Microsoft.Dashboard/grafana', parameters('grafanaName')), variables('monitoringReaderRoleDefinitionId'))]",
      "properties": {
        "roleDefinitionId": "[variables('monitoringReaderRoleDefinitionId')]",
        "principalId": "[reference(resourceId('Microsoft.Dashboard/grafana', parameters('grafanaName')), '2023-09-01', 'full').identity.principalId]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Dashboard/grafana', parameters('grafanaName'))]"
      ]
    }
  ],
  "outputs": {
