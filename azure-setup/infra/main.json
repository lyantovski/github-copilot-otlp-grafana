    "appInsightsResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/components', parameters('appInsightsName'))]"
    },
    "appInsightsConnectionString": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/components', parameters('appInsightsName')), '2020-02-02').ConnectionString]"
    },
    "managedGrafanaResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Dashboard/grafana', parameters('grafanaName'))]"
    },
    "managedGrafanaEndpoint": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Dashboard/grafana', parameters('grafanaName')), '2023-09-01').endpoint]"
